{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".svelte-kit/**", ".vercel/**", "dist/**"],
			"cache": false
		},
		"lint": {
			"dependsOn": ["^lint"],
			"cache": false
		},
		"check-types": {
			"dependsOn": ["^check-types"],
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"schema:watch": { "persistent": true, "cache": false },
		"codegen:watch": { "persistent": true, "cache": false, "dependsOn": ["^schema:watch"] }
	}
}
