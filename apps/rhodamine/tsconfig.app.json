{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"types": ["node", "vite/client"],
		"rootDir": "src",
		"module": "esnext",
		"moduleResolution": "bundler",
		"tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
		"paths": {
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"]
		}
	},
	"exclude": [
		"out-tsc",
		"dist",
		"src/**/*.spec.ts",
		"src/**/*.test.ts",
		"eslint.config.js",
		"eslint.config.cjs",
		"eslint.config.mjs"
	],
	"include": ["src/**/*.ts"],
	"references": [
		{
			"path": "../../libs/vali/tsconfig.lib.json"
		},
		{
			"path": "../../libs/types/tsconfig.lib.json"
		}
	]
}
