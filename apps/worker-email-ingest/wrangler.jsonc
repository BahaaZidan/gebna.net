{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "gebna-worker-email-ingest",
	"main": "./src/index.ts",
	"compatibility_date": "2026-03-15",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
	},
	"queues": {
		"producers": [
			{
				"queue": "gebna-queue-0",
				"binding": "Q",
			},
		],
		"consumers": [
			{
				"queue": "gebna-queue-0",
			},
		],
	},
}
