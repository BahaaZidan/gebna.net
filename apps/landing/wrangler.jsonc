{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gebna-net",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_flags": ["nodejs_compat"],
	"compatibility_date": "2026-03-15",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare",
	},
	"routes": [
		{
			"pattern": "gebna.net",
			"custom_domain": true,
		},
	],
	"observability": {
		"enabled": true,
	},
}
