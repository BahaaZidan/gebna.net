FROM node:24-bookworm-slim

WORKDIR /app
ENV NODE_ENV=production

# Native tools required for thumbnail generation
# - poppler-utils: PDF → PNG
# - libreoffice: Office → PDF
# - ffmpeg: Video → frame
# - fonts: sane rendering for document rendering
RUN apt-get update && apt-get install -y --no-install-recommends \
  poppler-utils \
  libreoffice \
  ffmpeg \
  fontconfig \
  fonts-dejavu-core \
  fonts-liberation \
  ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable

COPY package.json ./
RUN pnpm install --prod

COPY index.ts ./

ENV PORT=8787
EXPOSE 8787

CMD ["node", "index.ts"]
