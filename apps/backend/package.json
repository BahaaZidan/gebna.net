{
	"name": "backend",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "$npm_execpath run build && vite preview",
		"deploy": "$npm_execpath run build && wrangler deploy",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"tail": "wrangler tail",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "dotenv -e .dev.vars -- drizzle-kit migrate",
		"db:migrate:prod": "dotenv -e .prod.vars -- drizzle-kit migrate",
		"db:studio:local": "dotenv -e .dev.vars -- drizzle-kit studio",
		"db:studio:prod": "dotenv -e .prod.vars -- drizzle-kit studio",
		"db:seed": "node ./scripts/run-seed.mjs /seed/demo",
		"db:seed:raw": "node ./scripts/run-seed.mjs /seed/raw-emails",
		"r2:nuke": "node ./scripts/run-seed.mjs /seed/r2/nuke",
		"graphql:generate": "graphql-codegen --config ./graphql.config.ts"
	},
	"dependencies": {
		"@cloudflare/containers": "^0.0.31",
		"@gebna/validation": "workspace:*",
		"@libsql/client": "^0.15.15",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"argon2-wasm-edge": "^1.0.23",
		"aws4fetch": "^1.0.20",
		"drizzle-orm": "^0.44.7",
		"graphql": "^16.12.0",
		"graphql-scalars": "^1.25.0",
		"graphql-yoga": "^5.17.1",
		"hono": "^4.10.4",
		"html-to-text": "^9.0.5",
		"js-base64": "^3.7.8",
		"postal-mime": "^2.6.0",
		"ramda": "^0.32.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"remeda": "^2.32.0",
		"tldts": "^7.0.19",
		"turndown": "^7.2.2",
		"ulid": "^3.0.1",
		"unified": "^11.0.5",
		"xss": "^1.0.15"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.17.1",
		"@eslint/js": "^9.39.1",
		"@gebna/types": "workspace:*",
		"@graphql-codegen/add": "^6.0.0",
		"@graphql-codegen/cli": "^6.1.0",
		"@graphql-codegen/typescript": "^5.0.6",
		"@graphql-codegen/typescript-resolvers": "^5.1.4",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/aws-lambda": "^8.10.159",
		"@types/html-to-text": "^9.0.4",
		"@types/ramda": "^0.31.1",
		"@types/turndown": "^5.0.6",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.6",
		"eslint": "^9.39.1",
		"globals": "^16.5.0",
		"graphql-config": "^5.1.5",
		"tsx": "^4.21.0",
		"typescript-eslint": "^8.46.3",
		"vite": "^6.3.5",
		"vite-plugin-watch-and-run": "^1.7.5",
		"vite-ssr-components": "^0.5.1",
		"wrangler": "^4.54.0"
	}
}
