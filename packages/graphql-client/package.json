{
	"name": "@gebna/graphql-client",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "graphql-codegen-esm && tsc",
		"codegen": "graphql-codegen-esm",
		"codegen:watch": "chokidar \"../graphql-server/schema.graphql\" \"src/**/*\" \"../../apps/desktop/src/**/*\" \"../../apps/mobile/src/**/*\" \"../ui/src/**/*\" -c \"pnpm codegen\""
	},
	"peerDependencies": {
		"@urql/svelte": "^5.0.0",
		"svelte": "^5.50.0"
	},
	"dependencies": {
		"@urql/exchange-graphcache": "^9.0.0",
		"@urql/exchange-refocus": "^2.1.0",
		"@urql/exchange-retry": "^2.0.0",
		"graphql": "^16.12.0"
	},
	"devDependencies": {
		"@gebna/graphql-server": "workspace:*",
		"@graphql-codegen/cli": "^6.1.1",
		"@graphql-codegen/client-preset": "^5.2.2",
		"@graphql-codegen/typescript": "^5.0.7",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@parcel/watcher": "^2.5.6",
		"@repo/typescript-config": "workspace:*",
		"chokidar-cli": "^3.0.0",
		"concurrently": "^9.2.1",
		"graphql-config": "^5.1.5",
		"svelte": "^5.50.0",
		"svelte2tsx": "^0.7.48",
		"@urql/svelte": "^5.0.0",
		"typescript": "latest"
	}
}
