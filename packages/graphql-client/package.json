{
	"name": "@gebna/graphql-client",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"generate": "graphql-codegen-esm  --config ./graphql.config.ts",
		"watch": "graphql-codegen-esm -r ts-node/register --config ./graphql.config.ts --watch --verbose"
	},
	"dependencies": {
		"@urql/exchange-graphcache": "^9.0.0",
		"@urql/exchange-refocus": "^2.1.0",
		"@urql/exchange-retry": "^2.0.0",
		"@urql/svelte": "^5.0.0",
		"graphql": "^16.12.0"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^6.1.1",
		"@graphql-codegen/client-preset": "^5.2.2",
		"@graphql-codegen/typescript": "^5.0.7",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@parcel/watcher": "^2.5.6",
		"graphql-config": "^5.1.5",
		"svelte": "^5.50.0",
		"@repo/typescript-config": "workspace:*",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "latest",
		"@gebna/graphql-server": "workspace:*"
	}
}
