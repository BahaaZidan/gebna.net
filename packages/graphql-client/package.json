{
	"name": "@gebna/graphql-client",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "concurrently -n \"codegen,tsc\" -c \"blue,green\" \"pnpm watch\" \"pnpm tsc --watch\"",
		"build": "graphql-codegen-esm && tsc",
		"generate": "graphql-codegen-esm",
		"watch": "graphql-codegen-esm --watch"
	},
	"dependencies": {
		"@urql/exchange-graphcache": "^9.0.0",
		"@urql/exchange-refocus": "^2.1.0",
		"@urql/exchange-retry": "^2.0.0",
		"@urql/svelte": "^5.0.0",
		"graphql": "^16.12.0"
	},
	"devDependencies": {
		"@gebna/graphql-server": "workspace:*",
		"@graphql-codegen/cli": "^6.1.1",
		"@graphql-codegen/client-preset": "^5.2.2",
		"@graphql-codegen/typescript": "^5.0.7",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@parcel/watcher": "^2.5.6",
		"@repo/typescript-config": "workspace:*",
		"concurrently": "^9.2.1",
		"graphql-config": "^5.1.5",
		"svelte": "^5.50.0",
		"typescript": "latest"
	}
}
