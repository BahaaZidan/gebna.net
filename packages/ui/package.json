{
	"name": "@gebna/ui",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "svelte-kit sync && svelte-package --watch --input=src",
		"build": "svelte-kit sync && svelte-package --input=src",
		"lint": "eslint .",
		"check-types": "svelte-check --tsconfig ./tsconfig.json"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"src",
		"!src/**/*.test.*",
		"!src/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "catalog:"
	},
	"devDependencies": {
		"@formisch/svelte": "^0.7.1",
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/package": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"eslint": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"phosphor-svelte": "catalog:"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.5",
		"@gebna/graphql-client": "workspace:*",
		"date-fns": "^4.1.0"
	}
}
