{
	"name": "@gebna/db",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate:dev": "dotenv -e .env.dev -- drizzle-kit migrate",
		"db:migrate:prod": "dotenv -e .env.prod -- drizzle-kit migrate",
		"db:studio:dev": "dotenv -e .env.dev -- drizzle-kit studio",
		"db:studio:prod": "dotenv -e .env.prod -- drizzle-kit studio"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1"
	},
	"devDependencies": {
		"@libsql/client": "^0.17.0",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.8"
	}
}
