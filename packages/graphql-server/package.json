{
	"name": "@gebna/graphql-server",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"schema:export": "tsx scripts/export-schema.ts",
		"schema:watch": "chokidar \"src/**/*.{ts,tsx}\" -c \"pnpm schema:export\""
	},
	"dependencies": {
		"@gebna/db": "workspace:*",
		"@gebna/utils": "workspace:*",
		"@pothos/core": "^4.12.0",
		"graphql": "^16.12.0",
		"graphql-yoga": "^5.18.0"
	},
	"devDependencies": {
		"@gebna/auth": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"chokidar-cli": "^3.0.0",
		"tsx": "^4.19.1",
		"typescript": "latest"
	}
}
