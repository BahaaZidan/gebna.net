{
	"name": "@gebna/graphql-server",
	"version": "0.0.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"schema:export": "tsx scripts/export-schema.ts",
		"schema:watch": "chokidar \"src/**/*.{ts,tsx}\" -c \"pnpm schema:export\""
	},
	"dependencies": {
		"@gebna/db": "workspace:*",
		"@gebna/utils": "workspace:*",
		"@pothos/core": "^4.12.0",
		"@pothos/plugin-drizzle": "^0.17.0",
		"@pothos/plugin-relay": "^4.7.0",
		"@pothos/plugin-scope-auth": "^4.1.6",
		"@pothos/plugin-with-input": "^4.1.4",
		"graphql": "catalog:",
		"graphql-scalars": "^1.25.0",
		"graphql-yoga": "^5.18.0",
		"unist-util-visit": "catalog:"
	},
	"devDependencies": {
		"@gebna/auth": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"chokidar-cli": "^3.0.0",
		"tsx": "^4.19.1",
		"typescript": "catalog:"
	}
}
